# =============================================================================
# PIA WireGuard for Firewalla — configuration
# Copy to .env and fill in your values before running.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Your PIA username (format: p1234567)
PIA_USER=

# Your PIA password
PIA_PASS=

# ── Dedicated IP (optional) ───────────────────────────────────────────────────
# Leave blank to use a standard shared IP in the selected region.
# To use a PIA Dedicated IP: paste the token from your PIA account dashboard.
# When set, PIA_REGION is ignored — the server is determined by the DIP token.
DIP_TOKEN=

# ── Region (ignored when DIP_TOKEN is set) ────────────────────────────────────
# Run `./pia-wg-firewalla.sh list-regions` for a full list.
PIA_REGION=us_east

# ── Profile & interface naming ────────────────────────────────────────────────
# This becomes the WireGuard interface name AND the Firewalla VPN profile name.
# Stick to letters, numbers, _ and - only. Max 15 characters.
# Firewalla will show this name in its VPN Client → WireGuard list.
PROFILE_NAME=PIA_WG

# ── Firewalla integration mode ────────────────────────────────────────────────
# true  = Firewalla manages the WireGuard interface (recommended for native installs).
#         The script generates profile files and deploys them; you activate the
#         VPN once via the Firewalla app. The watchdog uses `wg syncconf` to
#         update the peer without restarting the interface.
# false = The script manages WireGuard directly via wg-quick (required for Docker).
WG_MANAGED_BY_FIREWALLA=false

# ── Storage ───────────────────────────────────────────────────────────────────
# Where to keep keys, token cache, server list cache, and generated configs.
# In Docker this should be a mounted volume so state survives container restarts.
DATA_DIR=/data/pia-wg

# ── DNS ───────────────────────────────────────────────────────────────────────
# Leave blank to use PIA's own DNS servers (recommended — prevents DNS leaks).
# Set to override, e.g. "1.1.1.1,1.0.0.1" or "9.9.9.9"
WG_DNS_OVERRIDE=

# ── Watchdog tuning ───────────────────────────────────────────────────────────
# How often the watchdog checks the connection (seconds)
WATCHDOG_INTERVAL=60

# How old a WireGuard handshake can be before we consider the tunnel stale (seconds)
HANDSHAKE_MAX_AGE=120

# How long the tunnel must be down before we attempt a full reconnect (seconds)
MAX_DOWN_TIME=300

# How many reconnect attempts before a 5-minute back-off pause
MAX_RECONNECT_ATTEMPTS=5

# IP to ping through the VPN to verify actual connectivity
VPN_CHECK_IP=9.9.9.9

# ── Token TTL ─────────────────────────────────────────────────────────────────
# How long (seconds) to trust a cached PIA token before refreshing.
# PIA tokens are valid for ~24 h; this defaults to 20 h for a safety margin.
TOKEN_TTL=72000

# How long (seconds) to cache the PIA server list before refreshing.
SERVER_LIST_TTL=86400
